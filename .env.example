# 问卷系统环境配置
# 复制此文件为 .env 并填写你的配置

# 邮件配置
EMAIL_RECEIVER=your-email@example.com  # 接收问卷数据的邮箱
EMAIL_SENDER=noreply@ip-questionnaire.com  # 发件人邮箱（显示用）
EMAIL_SUBJECT=【IP问卷】新提交 - {name}  # 邮件标题，{name}会被替换为用户姓名

# 问卷配置
QUESTIONNAIRE_TITLE=李密·IP深度挖掘问卷
QUESTIONNAIRE_DESCRIPTION=创始人信任资产与商业底盘深度盘查工具

# 微信分享配置（可选）
WECHAT_SHARE_TITLE=发现你的IP价值 - 深度问卷
WECHAT_SHARE_DESC=8个问题彻底盘点你的商业底盘与信任资产
WECHAT_SHARE_IMAGE=https://ip-questionnaire.vercel.app/logo.png

# 功能开关
ENABLE_VOICE_RECORDING=true
ENABLE_EMAIL_NOTIFICATION=true
ENABLE_LOCAL_STORAGE=true